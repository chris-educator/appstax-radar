# Gemini (required for Scout summaries + relevance scoring)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# SQLite path (Railway: mount volume at /app/data)
RADAR_DATA_PATH=./data/radar.db

# Protect review actions + manual scout trigger (generate a long random string)
RADAR_ADMIN_SECRET=

# Optional: separate cron secret (defaults to RADAR_ADMIN_SECRET)
RADAR_CRON_SECRET=

# Max items to process per scout run (summaries)
SCOUT_SUMMARIZE_BATCH=20

# Auto-publish when relevance >= threshold (0 = manual review only)
AUTO_PUBLISH_THRESHOLD=0.5
